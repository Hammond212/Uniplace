<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Uni Marketplace</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
    body {
        font-family: Arial, sans-serif;
        margin: 0;
        background: #f4f4f4;
    }

    header {
        background: #1e88e5;
        color: white;
        padding: 15px;
        text-align: center;
    }

    .container {
        max-width: 900px;
        margin: auto;
        padding: 20px;
    }

    .form-box {
        background: white;
        padding: 15px;
        border-radius: 10px;
        margin-bottom: 20px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    input, textarea {
        width: 100%;
        padding: 10px;
        margin-top: 5px;
        margin-bottom: 10px;
        border: 1px solid #ccc;
        border-radius: 5px;
    }

    button {
        background: #1e88e5;
        color: white;
        border: none;
        padding: 10px;
        cursor: pointer;
        border-radius: 5px;
    }

    button:hover {
        background: #1565c0;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 15px;
    }

    .card {
        background: white;
        padding: 15px;
        border-radius: 10px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .price {
        font-weight: bold;
        color: green;
    }

    .delete-btn {
        background: red;
        margin-top: 10px;
    }
</style>
</head>

<body>

<header>
    <h1>🎓 Uni Marketplace</h1>
    <p>Buy & Sell Student Products and Services</p>
</header>

<div class="container">

    <!-- FORM -->
    <div class="form-box">
        <h3>Upload Product / Service</h3>

        <input type="text" id="name" placeholder="Product/Service Name">
        <input type="text" id="price" placeholder="Price (e.g. P50)">
        <input type="text" id="seller" placeholder="Seller Name">
        <textarea id="description" placeholder="Description"></textarea>

        <button onclick="addProduct()">Add Listing</button>
    </div>

    <!-- PRODUCTS -->
    <div class="grid" id="productList"></div>

</div>

<script>
let products = JSON.parse(localStorage.getItem("products")) || [];

function saveProducts() {
    localStorage.setItem("products", JSON.stringify(products));
}

function addProduct() {
    let name = document.getElementById("name").value;
    let price = document.getElementById("price").value;
    let seller = document.getElementById("seller").value;
    let description = document.getElementById("description").value;

    if (!name || !price || !seller || !description) {
        alert("Please fill all fields!");
        return;
    }

    let product = {
        id: Date.now(),
        name,
        price,
        seller,
        description
    };

    products.push(product);
    saveProducts();
    renderProducts();

    document.getElementById("name").value = "";
    document.getElementById("price").value = "";
    document.getElementById("seller").value = "";
    document.getElementById("description").value = "";
}

function deleteProduct(id) {
    products = products.filter(p => p.id !== id);
    saveProducts();
    renderProducts();
}

function renderProducts() {
    let list = document.getElementById("productList");
    list.innerHTML = "";

    products.forEach(p => {
        list.innerHTML += `
            <div class="card">
                <h3>${p.name}</h3>
                <p>${p.description}</p>
                <p class="price">${p.price}</p>
                <p><i>Seller: ${p.seller}</i></p>
                <button class="delete-btn" onclick="deleteProduct(${p.id})">Delete</button>
            </div>
        `;
    });
}

renderProducts();
</script>

</body>
</html>
 
   




 

     
