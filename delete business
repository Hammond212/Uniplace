<!DOCTYPE html>
<html>
<head>
    <title>Uni Marketplace</title>
    <style>
        body {
            font-family: Arial;
        }
        .business-card {
            border: 1px solid #ccc;
            padding: 10px;
            margin: 10px;
            border-radius: 8px;
        }
        button {
            margin-top: 5px;
            padding: 5px 10px;
            cursor: pointer;
        }
        .delete-btn {
            background-color: red;
            color: white;
            border: none;
        }
    </style>
</head>
<body>

<h1>Marketplace</h1>

<div id="marketplace"></div>

<h2>Add Business</h2>
<input type="text" id="name" placeholder="Business Name">
<input type="text" id="desc" placeholder="Description">
<button onclick="addBusiness()">Add Business</button>

<script>
    function addBusiness() {
        let name = document.getElementById("name").value;
        let desc = document.getElementById("desc").value;

        if (name === "" || desc === "") {
            alert("Please fill in all fields");
            return;
        }

        let container = document.getElementById("marketplace");

        let card = document.createElement("div");
        card.className = "business-card";

        card.innerHTML = `
            <h3>${name}</h3>
            <p>${desc}</p>
            <button class="delete-btn" onclick="deleteBusiness(this)">Delete Business</button>
        `;

        container.appendChild(card);

        // Clear inputs
        document.getElementById("name").value = "";
        document.getElementById("desc").value = "";
    }

    function deleteBusiness(button) {
        let card = button.parentElement;

        if (confirm("Are you sure you want to delete this business?")) {
            card.remove();
        }
    }
</script>

</body>
</html>
